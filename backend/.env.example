# Backend defaults for local development.
# In the Electron app, set the DashScope key and realtime model in Settings.

TRANSLATION_PROVIDER=aliyun_livetranslate
DASHSCOPE_API_KEY=
DASHSCOPE_LIVETRANSLATE_MODEL=qwen3.5-livetranslate-flash-realtime
DASHSCOPE_TTS_MODEL=cosyvoice-v2
DASHSCOPE_TTS_VOICE=longfeifei_v2

SOURCE_LANG=en
TARGET_LANG=zh
ENABLE_CORRECTION=true
