# Application
APP_NAME=AI Interpreter
APP_VERSION=2.0.0
DEBUG=true
HOST=0.0.0.0
PORT=9000

# Provider
# aliyun_livetranslate is the current realtime test path.
# xiaomi remains available for legacy code paths.
TRANSLATION_PROVIDER=aliyun_livetranslate

# Aliyun Bailian / DashScope realtime speech translation
# Never commit a real API key. Use a RAM-scoped account/key.
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_LIVETRANSLATE_MODEL=qwen3.5-livetranslate-flash-realtime
DASHSCOPE_SECOND_LIVETRANSLATE_MODEL=qwen3.5-livetranslate-flash-realtime
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-realtime
DASHSCOPE_TEXT_MODEL=qwen-flash
DASHSCOPE_REPAIR_MODEL=qwen-plus-latest
ENABLE_SECOND_E2E=false
LIVETRANSLATE_SILENCE_DURATION_MS=480
SECOND_E2E_SILENCE_DURATION_MS=300
ENABLE_ASR_FALLBACK=false
ASR_FALLBACK_TRANSLATE=false
AUDIO_REPLAY_SECONDS=2.0
DEBUG_REALTIME_EVENTS=false
ENABLE_CONTEXTUAL_REPAIR=true
CONTEXTUAL_REPAIR_MAX_CHARS=260
CONTEXTUAL_REPAIR_WINDOW_SIZE=3

# Default languages
SOURCE_LANG=en
TARGET_LANG=zh

# Optional correction settings
ENABLE_CORRECTION=true
CORRECTION_BUFFER_SIZE=5

# Legacy Xiaomi settings, only needed when TRANSLATION_PROVIDER=xiaomi
XIAOMI_API_KEY=
XIAOMI_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
XIAOMI_API_ENDPOINT=
XIAOMI_ASR_MODEL=mimo-v2.5-asr
XIAOMI_LLM_MODEL=mimo-v2.5
XIAOMI_TTS_MODEL=mimo-v2.5-tts
