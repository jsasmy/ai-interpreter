# 小米语音识别API配置
XIAOMI_ASR_API_KEY=your_api_key_here
XIAOMI_ASR_API_URL=your_api_url_here

# 翻译API配置
TRANSLATE_API_KEY=your_api_key_here
TRANSLATE_API_URL=your_api_url_here

# TTS语音合成API配置（可选）
TTS_API_KEY=your_api_key_here
TTS_API_URL=your_api_url_here

# Aliyun Bailian end-to-end realtime speech translation
# Never commit a real API key. Create it from a RAM-scoped Bailian account.
TRANSLATION_PROVIDER=aliyun_livetranslate
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_LIVETRANSLATE_MODEL=qwen3.5-livetranslate-flash-realtime-2026-05-19
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-realtime
